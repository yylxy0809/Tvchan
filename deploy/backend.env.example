# Copy this file to deploy/backend.env, edit it, then run:
# docker compose --env-file deploy/backend.env -f deploy/docker-compose.backend.yml up -d --build

APP_ENV=production
API_TOKEN=change-me-long-random-token
ADMIN_API_TOKEN=change-me-admin-token
# If you use the built-in frontend admin login, keep this value aligned with
# the frontend's configured admin token.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,http://192.168.1.5:8080,https://515178.xyz
# Optional. Useful when the public frontend origin changes often.
# Example: CORS_ORIGIN_REGEX=https://.*\.example\.com
CORS_ORIGIN_REGEX=
# Optional public URL used by docs and future generated links.
PUBLIC_BASE_URL=
WEB_GATEWAY_BIND=0.0.0.0
WEB_GATEWAY_PORT=8080
CLOUDFLARED_TOKEN=
LLM_ENABLED=true
LLM_API_KEY=
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V3.2
LLM_TIMEOUT_SECONDS=20

POSTGRES_DB=tradingview_local
POSTGRES_USER=trader
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=5432

REDIS_BIND=127.0.0.1
REDIS_PORT=6379
CHAN_SERVICE_BIND=127.0.0.1
CHAN_SERVICE_PORT=8002
API_BIND=0.0.0.0
API_PORT=8001

# Bind-mount paths on the Docker host.
# Windows example: C:/Users/yangyang/Documents/Codex/2026-06-13/tradingview-tradingview-a-5f-15f-30f/work/vendor/chan.py-main
# NAS example: /volume1/docker/tradingview/vendor/chan.py-main
CHAN_ENGINE_MODE=module_b
CHAN_PY_HOST_PATH=../work/vendor/chan.py-main

# Optional local zipped TDX CSV history. Required only for the tdx-csv-import profile.
# Windows example: D:/BaiduNetdiskDownload/tdx-data
# NAS example: /volume1/market-data/tdx-data
TDX_CSV_HOST_ROOT=../work/tdx-csv

TDX_HOST=124.70.199.56
TDX_PORT=7709
TDX_TIMEOUT=10
TDX_RETRIES=3

MARKET_FILL_PROVIDER=pytdx
MARKET_FILL_SYMBOL_LIMIT=10
MARKET_FILL_TIMEFRAMES=5f,15f,30f,1h,1d,1w,1m
MARKET_FILL_BAR_LIMIT=300
MARKET_FILL_SLEEP=0.25
MARKET_FILL_LOOP=1
MARKET_FILL_LOOP_INTERVAL=60
MARKET_FILL_CHAN_LEVELS=5f,30f,1d
MARKET_FILL_MODES=confirmed,predictive

HISTORY_BACKFILL_PROVIDER=pytdx
HISTORY_BACKFILL_SYMBOL_LIMIT=1
HISTORY_BACKFILL_TIMEFRAMES=5f
HISTORY_BACKFILL_PAGE_SIZE=800
HISTORY_BACKFILL_TASK_LIMIT=3
HISTORY_BACKFILL_CONCURRENCY=1
HISTORY_BACKFILL_MAX_PAGES_PER_TASK=1
HISTORY_BACKFILL_LOOP=1
HISTORY_BACKFILL_LOOP_INTERVAL=30
HISTORY_BACKFILL_RESET_RUNNING=1

CHAN_RECOMPUTE_SYMBOL_LIMIT=10
CHAN_RECOMPUTE_BASE_TIMEFRAME=5f
CHAN_RECOMPUTE_LEVELS=5f,30f,1d
CHAN_RECOMPUTE_MODES=confirmed,predictive
CHAN_RECOMPUTE_TASK_LIMIT=3
CHAN_RECOMPUTE_CONCURRENCY=1
CHAN_RECOMPUTE_LOOP=1
CHAN_RECOMPUTE_LOOP_INTERVAL=60
CHAN_RECOMPUTE_RESET_RUNNING=1
CHAN_ANALYZE_TIMEOUT=180

TDX_CSV_TIMEFRAMES=5f
TDX_CSV_SYMBOL_LIMIT=0
TDX_CSV_CATEGORIES=1
TDX_CSV_ASSET_TYPES=stock
TDX_CSV_FQ=0
TDX_CSV_TASK_LIMIT=1
TDX_CSV_CONCURRENCY=1
TDX_CSV_ENTRY_BATCH_SIZE=50
TDX_CSV_BAR_BATCH_SIZE=50000
TDX_CSV_RESET_RUNNING=1
TDX_CSV_LOOP=1
TDX_CSV_LOOP_INTERVAL=300

