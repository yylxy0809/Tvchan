FROM python:3.11-slim@sha256:e031123e3d85762b141ad1cbc56452ba69c6e722ebf2f042cc0dc86c47c0d8b3

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app/services/collector:/app/libs/protocol/python:/app/services/api

WORKDIR /app

COPY services/collector/requirements.txt /tmp/collector-requirements.txt
COPY services/api/requirements.txt /tmp/api-requirements.txt
RUN apt-get update \
    && pip install --no-cache-dir -r /tmp/collector-requirements.txt -r /tmp/api-requirements.txt \
    && rm -rf /var/lib/apt/lists/*

COPY libs/protocol/python /app/libs/protocol/python
COPY services/api /app/services/api
COPY services/collector /app/services/collector

WORKDIR /app/services/collector

CMD ["python", "-m", "collector.worker", "chan-c-stream"]
