# Local logs, packages, scratch output
logs/
outputs/
tmp/
tmp-*
work/
*.log
*.pid
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz

# Licensed/runtime-only assets copied outside source control
apps/web/public/charting_library/

