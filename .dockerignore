# Git and editor state
.git
.gitignore
.dockerignore
.vs/
.vscode/

# Local secrets and runtime config
.env
.env.*
deploy/*.env
deploy/*.env.*
!deploy/*.env.example

# Python caches and virtualenvs
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
