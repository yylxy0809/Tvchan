# Shared
APP_ENV=development
API_TOKEN=

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
USE_SEED_DATA=true

# Database
DATABASE_URL=postgresql://trader:trader@localhost:5432/tradingview_local

# Redis
REDIS_URL=redis://localhost:6379/0

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_API_TOKEN=

# Optional market-data profile. Provide a supplied WeStock bundle, its fixed SHA-256,
# and the factory paths implementing your separately verified provider contracts.
MARKET_DATA_PROVIDER_FACTORY=collector.market_data.factory:create_market_data_provider
MARKET_DATA_DEMAND_REPOSITORY_FACTORY=
MARKET_DATA_ACTIVE_SYMBOL=
MARKET_DATA_WATCHLIST=
MARKET_DATA_MAX_CONTEXTS=1000
MARKET_DATA_INTERVAL_SECONDS=5
MARKET_DATA_TIMEOUT_SECONDS=12
MARKET_DATA_MAX_STRUCTURED_SYMBOLS_PER_REFRESH=2
WESTOCK_PROVIDER_BUNDLE_HOST_PATH=
WESTOCK_BRIDGE_MODULE=/run/westock-verified/provider.mjs
WESTOCK_BRIDGE_SHA256=
WESTOCK_PROCESS_POOL_SIZE=5
WESTOCK_TIMEOUT_SECONDS=10
WESTOCK_MAX_OUTPUT_BYTES=1048576
WESTOCK_BATCH_SIZE=100
WESTOCK_NORMALIZER_FACTORY=
IWENCAI_BASE_URL=https://openapi.iwencai.com
IWENCAI_API_KEY=
IWENCAI_ALLOWED_HOSTS=openapi.iwencai.com
IWENCAI_TIMEOUT_SECONDS=5
MARKET_DATA_MAX_PROVIDER_CONCURRENCY=16
WESTOCK_MAX_TRANSPORT_CONCURRENCY=16
IWENCAI_MASTER_DATA_RESOLVER_FACTORY=
